<Window x:Class="OTTimetableApp.AdminLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Login" Height="230" Width="340"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.ColumnSpan="2" Text="Admin Login"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Text="Username:" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox x:Name="UsernameBox" Grid.Row="1" Grid.Column="1"
                 Margin="0,0,0,8" KeyDown="Input_KeyDown"/>

        <TextBlock Grid.Row="2" Text="Password:" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="2" Grid.Column="1"
                     Margin="0,0,0,8" KeyDown="Input_KeyDown"/>

        <TextBlock x:Name="ErrorText" Grid.Row="3" Grid.ColumnSpan="2"
                   Foreground="Red" FontSize="11" Margin="0,0,0,8"
                   Text="Invalid username or password." Visibility="Collapsed"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Login" Width="80" Margin="0,0,10,0" Click="Login_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
