<Window x:Class="OTTimetableApp.DateRangePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Date Range for PDF Export" 
        Height="400" Width="450" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Choose the date range to export:"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1">
            <!-- Month Selection -->
            <RadioButton x:Name="MonthRadio" 
                        Content="Select Month"
                        GroupName="DateRangeMode"
                        IsChecked="True"
                        Margin="0,0,0,10"
                        Checked="MonthRadio_Checked"/>
            
            <StackPanel Margin="25,0,0,20">
                <TextBlock Text="Month:" Margin="0,0,0,5"/>
                <DatePicker x:Name="MonthPicker"
                           Width="200"
                           HorizontalAlignment="Left"
                           SelectedDateChanged="MonthPicker_SelectedDateChanged"/>
            </StackPanel>

            <!-- Custom Date Range -->
            <RadioButton x:Name="CustomRadio"
                        Content="Custom Date Range"
                        GroupName="DateRangeMode"
                        Margin="0,0,0,10"
                        Checked="CustomRadio_Checked"/>
            
            <StackPanel Margin="25,0,0,0">
                <TextBlock Text="Start Date:" Margin="0,0,0,5"/>
                <DatePicker x:Name="StartDatePicker"
                           Width="200"
                           HorizontalAlignment="Left"
                           IsEnabled="False"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="End Date:" Margin="0,0,0,5"/>
                <DatePicker x:Name="EndDatePicker"
                           Width="200"
                           HorizontalAlignment="Left"
                           IsEnabled="False"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,15,0,0">
            <Button Content="Export to PDF" 
                   Width="120" 
                   Height="32"
                   Click="Export_Click"
                   IsDefault="True"
                   Margin="0,0,10,0"/>
            <Button Content="Cancel" 
                   Width="80" 
                   Height="32"
                   Click="Cancel_Click"
                   IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
