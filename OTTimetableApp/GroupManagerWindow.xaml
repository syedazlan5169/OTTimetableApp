<Window x:Class="OTTimetableApp.GroupManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Group Manager" Height="600" Width="650"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top -->
        <DockPanel Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock Text="Group:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="220"
                          ItemsSource="{Binding Groups}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedGroupId}"/>
            </StackPanel>

            <TextBlock Text="{Binding GroupTitle}"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Capacity -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Slot Capacity:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Width="60" Height="26" Text="{Binding SlotCapacity, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Apply" Width="90" Margin="10,0,0,0" Click="ApplyCapacity_Click"/>
                <TextBlock Margin="12,0,0,0" Foreground="DimGray" VerticalAlignment="Center"
                           Text="Reducing capacity removes members beyond capacity."/>
            </StackPanel>

            <!-- Slots -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Slots}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Slot" Binding="{Binding SlotIndex}" Width="80" IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="Employee" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Employees, RelativeSource={RelativeSource AncestorType=Window}}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding EmployeeId}"
                                          DropDownClosed="SlotChanged_DropDownClosed"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>