<Window x:Class="OTTimetableApp.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Stats Dashboard" Height="740" Width="1100"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Calendar:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="CalendarFilter" Width="200"
                      DisplayMemberPath="Display" SelectedValuePath="Id" Margin="0,0,16,0"/>
            <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="MonthFilter" Width="120"
                      DisplayMemberPath="Name" SelectedValuePath="Month" Margin="0,0,16,0"/>
            <Button x:Name="LoadButton" Content="Load" Width="80" Click="Load_Click"/>
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center"
                       Margin="12,0,0,0" Foreground="Gray" FontSize="11"/>
        </StackPanel>

        <!-- Summary cards -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="TotalShiftsText" Text="—" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Total OT Hours" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="TotalReplacementsText" Text="—" FontSize="26" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#E6A817"/>
                    <TextBlock Text="Total Claim Lines" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="TotalEmptyFillsText" Text="—" FontSize="26" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#4FC3F7"/>
                    <TextBlock Text="Employees with OT" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12,8">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="TotalPHsText" Text="—" FontSize="26" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#EF9A9A"/>
                    <TextBlock Text="Highest OT (hours)" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Charts 2×2 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0,0,6,6">
                <oxy:PlotView x:Name="TopShiftsChart" Margin="4"/>
            </Border>
            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0,0,0,6">
                <oxy:PlotView x:Name="ShiftTypeChart" Margin="4"/>
            </Border>
            <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0">
                <oxy:PlotView x:Name="TopReplacementsChart" Margin="4"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                <oxy:PlotView x:Name="MonthlyTrendChart" Margin="4"/>
            </Border>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Close" Width="80" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
