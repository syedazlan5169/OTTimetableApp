<Window x:Class="OTTimetableApp.ClaimPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Claim" Height="720" Width="948"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top controls -->
        <DockPanel Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock Text="Calendar:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="240"
                          ItemsSource="{Binding Calendars}"
                          DisplayMemberPath="Display"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedCalendarId}"
                          Margin="0,0,12,0"/>

                <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="160"
                          ItemsSource="{Binding Months}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Month"
                          SelectedValue="{Binding SelectedMonth}"
                          Margin="0,0,12,0"/>

                <TextBlock Text="Employee:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="180"
                          ItemsSource="{Binding Employees}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedEmployeeId}"/>

                <Button Content="Generate" Width="120" Margin="12,0,0,0" Click="Generate_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Table -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Lines}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="" Binding="{Binding IsChecked}" Width="45"/>
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="110"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="200"/>
                <DataGridTextColumn Header="OT Shift" Binding="{Binding Shift}" Width="120"/>

                <DataGridTextColumn Header="1.125" Binding="{Binding H1125, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="1.25"  Binding="{Binding H125, StringFormat=N2}"  Width="80"/>
                <DataGridTextColumn Header="1.5"   Binding="{Binding H15, StringFormat=N2}"   Width="80"/>
                <DataGridTextColumn Header="1.75"  Binding="{Binding H175, StringFormat=N2}"  Width="80"/>
                <DataGridTextColumn Header="2.0"   Binding="{Binding H20, StringFormat=N2}"   Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>