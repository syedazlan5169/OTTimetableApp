<Window x:Class="OTTimetableApp.ClaimPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Claim" Height="720" Width="1036"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top controls -->
        <DockPanel Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock Text="Calendar:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="240"
                          ItemsSource="{Binding Calendars}"
                          DisplayMemberPath="Display"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedCalendarId}"
                          Margin="0,0,12,0"/>

                <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="160"
                          ItemsSource="{Binding Months}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Month"
                          SelectedValue="{Binding SelectedMonth}"
                          Margin="0,0,12,0"/>

                <TextBlock Text="Employee:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="180"
                          ItemsSource="{Binding Employees}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedEmployeeId}"/>

                <Button Content="Generate" Width="120" Margin="12,0,0,0" Click="Generate_Click"/>

                <CheckBox Content="All"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          IsChecked="{Binding AllChecked, Mode=TwoWay}"/>
            </StackPanel>
        </DockPanel>

        <!-- Table -->
        <DataGrid Grid.Row="1"
                  Margin="0,0,0,10"
                  ItemsSource="{Binding Lines}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False">
            <DataGrid.Columns>

                <DataGridCheckBoxColumn Header="✔" Binding="{Binding IsChecked}" Width="45"/>
                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="200"/>
                <DataGridTextColumn Header="OT Shift" Binding="{Binding Shift}" Width="120"/>

                <DataGridTextColumn Header="1.125" Binding="{Binding H1125, StringFormat={}{0:N2}, TargetNullValue=''}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="1.25" Binding="{Binding H125, StringFormat={}{0:N2}, TargetNullValue=''}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="1.5" Binding="{Binding H15, StringFormat={}{0:N2}, TargetNullValue=''}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="1.75" Binding="{Binding H175, StringFormat={}{0:N2}, TargetNullValue=''}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="2.0" Binding="{Binding H20, StringFormat={}{0:N2}, TargetNullValue=''}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Remark" Binding="{Binding Remark}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,10,0,0">

            <TextBlock Text="{Binding HourlyRate, StringFormat=Hourly Rate: RM {0:N2}}"
               FontWeight="Bold"/>

            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding Total1125, StringFormat=1.125 Hours: {0:N2}}"/>
                <TextBlock Grid.Column="1" Text="{Binding Total125, StringFormat=1.25 Hours: {0:N2}}"/>
                <TextBlock Grid.Column="2" Text="{Binding Total15, StringFormat=1.5 Hours: {0:N2}}"/>
                <TextBlock Grid.Column="3" Text="{Binding Total175, StringFormat=1.75 Hours: {0:N2}}"/>
                <TextBlock Grid.Column="4" Text="{Binding Total20, StringFormat=2.0 Hours: {0:N2}}"/>
            </Grid>

            <TextBlock Margin="0,8,0,0"
               FontWeight="Bold"
               Text="{Binding ExcessWorkingHours, StringFormat=Lebihan Jam Bertugas: {0:N2} hours}"/>

            <TextBlock Margin="0,8,0,0"
               FontSize="16"
               FontWeight="Bold"
               Text="{Binding GrandTotal, StringFormat=Total Claim: RM {0:N2}}"/>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Catatan Lampiran E:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding CatatanLampiranE, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Catatan Lampiran A:" VerticalAlignment="Top" Margin="0,2,6,0"/>
                <TextBox Grid.Column="4"
                         Text="{Binding CatatanLampiranA, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="40"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <Button Content="Export to Excel"
                    Width="150" 
                    Height="35"
                    Margin="0,15,0,0" 
                    Click="Export_Click"
                    HorizontalAlignment="Left"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>