<Window x:Class="OTTimetableApp.CalendarManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calendar Manager" Height="420" Width="700" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Create Calendar" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Name:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Margin="0,0,10,6"/>

                <TextBlock Text="Year:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                <TextBox x:Name="YearBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,6" Text="2026"/>

                <TextBlock Text="Init Night (22-07):" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="InitNight" Grid.Row="1" Grid.Column="1" Margin="0,0,10,6"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Init Morning (07-15):" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"/>
                <ComboBox x:Name="InitMorning" Grid.Row="1" Grid.Column="3" Margin="0,0,0,6"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Init Evening (14-23):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="InitEvening" Grid.Row="2" Grid.Column="1" Margin="0,0,10,0"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <Button Grid.Row="2" Grid.Column="3" Content="Create Calendar"
                        HorizontalAlignment="Right" Width="170"
                        Click="Create_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Existing Calendars" Padding="10" Margin="0,12,0,0">
            <DataGrid x:Name="CalendarGrid" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Generated" Binding="{Binding IsGenerated}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Generate Year" Width="130" Margin="0,0,10,0" Click="Generate_Click"/>
            <Button Content="Delete Calendar" Width="130" Margin="0,0,10,0" Click="Delete_Click"/>
            <Button Content="Close" Width="100" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>