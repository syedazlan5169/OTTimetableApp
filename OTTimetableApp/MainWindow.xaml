<Window x:Class="OTTimetableApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OT Timetable" Height="750" Width="1250">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <DockPanel Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock Text="Calendar:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="220"
                          ItemsSource="{Binding Calendars}"
                          DisplayMemberPath="Display"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedCalendarId}"
                          SelectionChanged="Calendar_Changed"
                          Margin="0,0,12,0"/>

                <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="160"
                          ItemsSource="{Binding Months}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Month"
                          SelectedValue="{Binding SelectedMonth}"
                          SelectionChanged="Month_Changed"/>
            </StackPanel>

            <TextBlock Text="{Binding MonthTitle}"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Timetable grid (month only) -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Days}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  EnableRowVirtualization="False"
                  EnableColumnVirtualization="False"
                  VirtualizingPanel.IsVirtualizing="False"
                  ScrollViewer.CanContentScroll="False">
            <DataGrid.Columns>

                <!-- Date / PH -->
                <DataGridTemplateColumn Header="Tarikh" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DateDisplay}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding DayName}" />
                                <CheckBox Content="Public Holiday"
                                          IsChecked="{Binding IsPublicHoliday}"
                                          IsEnabled="True"/>
                                <TextBox Text="{Binding PublicHolidayName}" Height="24"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Night -->
                <DataGridTemplateColumn Header="22:00 - 07:00" Width="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Night.GroupName}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <ItemsControl ItemsSource="{Binding Night.Slots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,2">
                                                <TextBlock Text="{Binding SlotIndex}" Width="20"/>
                                                <ComboBox Width="200"
                                                          ItemsSource="{Binding EmployeeOptions}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding ActualEmployeeId}"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Morning -->
                <DataGridTemplateColumn Header="07:00 - 15:00" Width="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Morning.GroupName}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <ItemsControl ItemsSource="{Binding Morning.Slots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,2">
                                                <TextBlock Text="{Binding SlotIndex}" Width="20"/>
                                                <ComboBox Width="200"
                                                          ItemsSource="{Binding EmployeeOptions}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding ActualEmployeeId}"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Evening -->
                <DataGridTemplateColumn Header="14:00 - 23:00" Width="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Evening.GroupName}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <ItemsControl ItemsSource="{Binding Evening.Slots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,2">
                                                <TextBlock Text="{Binding SlotIndex}" Width="20"/>
                                                <ComboBox Width="200"
                                                          ItemsSource="{Binding EmployeeOptions}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding ActualEmployeeId}"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- OFF -->
                <DataGridTemplateColumn Header="OFF" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding OffGroupName}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <ItemsControl ItemsSource="{Binding OffGroupMembers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>