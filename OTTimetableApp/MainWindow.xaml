<Window x:Class="OTTimetableApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OT Timetable" Height="850" Width="1365" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <StackPanel Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Calendar:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="220"
                          ItemsSource="{Binding Calendars}"
                          DisplayMemberPath="Display"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedCalendarId}"
                          SelectionChanged="Calendar_Changed"
                          Margin="0,0,12,0"/>

                <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="160"
                          ItemsSource="{Binding Months}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Month"
                          SelectedValue="{Binding SelectedMonth}"
                          SelectionChanged="Month_Changed"/>

                <Button Content="Manage Calendars"
                        Width="140"
                        Margin="12,0,0,0"
                        Click="ManageCalendars_Click"/>

                <Button Content="Manage Employees"
                        Width="140"
                        Margin="12,0,0,0"
                        Click="ManageEmployees_Click"/>

                <Button Content="Manage Groups"
                        Width="120"
                        Margin="10,0,0,0"
                        Click="ManageGroups_Click"/>

                <!-- <Button Content="Debug Claim" Width="110" Margin="12,0,0,0" Click="DebugClaim_Click"/> -->
                <Button Content="Create Claim" Width="140" Margin="10,0,0,0" Click="CreateClaim_Click"/>

                <Button Content="Database Setup" Width="140" Margin="10,0,0,0" Click="DatabaseSetup_Click"/>
                
            </StackPanel>

            <TextBlock Text="{Binding MonthTitle}"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Timetable grid (month only) -->
        <DataGrid x:Name="TimetableGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Days}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  EnableRowVirtualization="False"
                  EnableColumnVirtualization="False"
                  VirtualizingPanel.IsVirtualizing="False"
                  ScrollViewer.CanContentScroll="False">
            <DataGrid.Columns>

                <!-- Date / PH -->
                <DataGridTemplateColumn Header="Tarikh" Width="200" IsReadOnly="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPublicHoliday}" Value="True">
                                                <Setter Property="Background" Value="#FFFFE5E5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel>
                                    <TextBlock Text="{Binding DateDisplay}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding DayName}" />

                                    <!-- PH Label -->
                                    <TextBlock Text="PUBLIC HOLIDAY"
                               Foreground="Red"
                               FontWeight="Bold"
                               Visibility="Collapsed">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPublicHoliday}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Text="{Binding PublicHolidayName}"
                               Foreground="DarkRed"
                               FontStyle="Italic"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DateDisplay}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding DayName}" />

                                <CheckBox Content="Public Holiday"
                          IsChecked="{Binding IsPublicHoliday, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Click="PH_Click"/>

                                <TextBox Text="{Binding PublicHolidayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="24"
                         LostFocus="PHName_LostFocus"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Night -->
                <DataGridTemplateColumn Header="22:00 - 07:00" Width="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Group name -->
                                <TextBlock Text="{Binding Night.GroupName}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                                <!-- Slots -->
                                <ItemsControl ItemsSource="{Binding Night.Slots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding SlotIndex}" Width="20" VerticalAlignment="Center"/>

                                                    <!-- Status badge -->
                                                    <Border Width="72" Height="22" CornerRadius="6"
                                            Margin="6,0,6,0" Padding="6,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="LightGray"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FillType}" Value="Planned">
                                                                        <Setter Property="Background" Value="LightGreen"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FillType}" Value="Replacement">
                                                                        <Setter Property="Background" Value="Khaki"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FillType}" Value="EmptyFill">
                                                                        <Setter Property="Background" Value="LightSkyBlue"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>

                                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Combo -->
                                                    <ComboBox Width="200"
                                              ItemsSource="{Binding EmployeeOptions}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding ActualEmployeeId, TargetNullValue=0}"
                                              DropDownClosed="Slot_DropDownClosed">
                                                        <ComboBox.ItemContainerStyle>
                                                            <Style TargetType="ComboBoxItem">
                                                                <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                                                            </Style>
                                                        </ComboBox.ItemContainerStyle>
                                                    </ComboBox>
                                                </DockPanel>

                                                <!-- Replaces who -->
                                                <TextBlock Margin="98,2,0,0"
                                           FontSize="11"
                                           Foreground="SlateGray"
                                           Text="{Binding ReplacesName, StringFormat=Replaces: {0}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FillType}" Value="Replacement">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- On Leave -->
                                                <TextBlock Margin="98,2,0,0"
                                           FontSize="11"
                                           Foreground="DarkOrange"
                                           Text="{Binding OnLeaveName, StringFormat=On Leave: {0}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasOnLeaveName}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Morning -->
                <DataGridTemplateColumn Header="07:00 - 15:00" Width="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Group name -->
                                <TextBlock Text="{Binding Morning.GroupName}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                                <!-- Slots -->
                                <ItemsControl ItemsSource="{Binding Morning.Slots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding SlotIndex}" Width="20" VerticalAlignment="Center"/>

                                                    <!-- Status badge -->
                                                    <Border Width="72" Height="22" CornerRadius="6"
                                            Margin="6,0,6,0" Padding="6,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="LightGray"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FillType}" Value="Planned">
                                                                        <Setter Property="Background" Value="LightGreen"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FillType}" Value="Replacement">
                                                                        <Setter Property="Background" Value="Khaki"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FillType}" Value="EmptyFill">
                                                                        <Setter Property="Background" Value="LightSkyBlue"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>

                                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Combo -->
                                                    <ComboBox Width="200"
                                              ItemsSource="{Binding EmployeeOptions}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding ActualEmployeeId, TargetNullValue=0}"
                                              DropDownClosed="Slot_DropDownClosed">
                                                        <ComboBox.ItemContainerStyle>
                                                            <Style TargetType="ComboBoxItem">
                                                                <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                                                            </Style>
                                                        </ComboBox.ItemContainerStyle>
                                                    </ComboBox>
                                                </DockPanel>

                                                <!-- Replaces who -->
                                                <TextBlock Margin="98,2,0,0"
                                           FontSize="11"
                                           Foreground="SlateGray"
                                           Text="{Binding ReplacesName, StringFormat=Replaces: {0}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FillType}" Value="Replacement">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- On Leave -->
                                                <TextBlock Margin="98,2,0,0"
                                           FontSize="11"
                                           Foreground="DarkOrange"
                                           Text="{Binding OnLeaveName, StringFormat=On Leave: {0}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasOnLeaveName}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Evening -->
                <DataGridTemplateColumn Header="14:00 - 23:00" Width="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Group name -->
                                <TextBlock Text="{Binding Evening.GroupName}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                                <!-- Slots -->
                                <ItemsControl ItemsSource="{Binding Evening.Slots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding SlotIndex}" Width="20" VerticalAlignment="Center"/>

                                                    <!-- Status badge -->
                                                    <Border Width="72" Height="22" CornerRadius="6"
                                            Margin="6,0,6,0" Padding="6,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="LightGray"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FillType}" Value="Planned">
                                                                        <Setter Property="Background" Value="LightGreen"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FillType}" Value="Replacement">
                                                                        <Setter Property="Background" Value="Khaki"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FillType}" Value="EmptyFill">
                                                                        <Setter Property="Background" Value="LightSkyBlue"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>

                                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Combo -->
                                                    <ComboBox Width="200"
                                              ItemsSource="{Binding EmployeeOptions}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding ActualEmployeeId, TargetNullValue=0}"
                                              DropDownClosed="Slot_DropDownClosed">
                                                        <ComboBox.ItemContainerStyle>
                                                            <Style TargetType="ComboBoxItem">
                                                                <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                                                            </Style>
                                                        </ComboBox.ItemContainerStyle>
                                                    </ComboBox>
                                                </DockPanel>

                                                <!-- Replaces who -->
                                                <TextBlock Margin="98,2,0,0"
                                           FontSize="11"
                                           Foreground="SlateGray"
                                           Text="{Binding ReplacesName, StringFormat=Replaces: {0}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FillType}" Value="Replacement">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- On Leave -->
                                                <TextBlock Margin="98,2,0,0"
                                           FontSize="11"
                                           Foreground="DarkOrange"
                                           Text="{Binding OnLeaveName, StringFormat=On Leave: {0}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasOnLeaveName}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- OFF -->
                <DataGridTemplateColumn Header="OFF" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding OffGroupName}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <ItemsControl ItemsSource="{Binding OffGroupMembers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>