<Window x:Class="OTTimetableApp.DatabaseSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Setup" Width="640"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="12">
        <TextBlock FontWeight="Bold" FontSize="14"
                   Text="Set database connection and run migrations." Margin="0,0,0,10"/>

        <!-- MySQL connection fields -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Host:" Margin="0,0,0,6"/>
            <TextBox x:Name="HostBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"/>

            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Database:" Margin="0,0,0,6"/>
            <TextBox x:Name="DatabaseBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,6"/>

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="User:" Margin="0,0,0,6"/>
            <TextBox x:Name="UserBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,6"/>

            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Password:"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="3" Grid.Column="1"/>
        </Grid>

        <!-- SSH toggle -->
        <CheckBox x:Name="SshCheckBox" Content="Use SSH Tunnel" Margin="0,12,0,4"
                  Checked="SshCheckBox_Changed" Unchecked="SshCheckBox_Changed"/>

        <!-- SSH settings panel -->
        <GroupBox x:Name="SshGroupBox" Header="SSH Tunnel Settings"
                  Visibility="Collapsed" Margin="0,0,0,0" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="SSH Host:" Margin="0,0,0,6"/>
                <TextBox x:Name="SshHostBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="SSH Port:" Margin="0,0,0,6"/>
                <TextBox x:Name="SshPortBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="SSH User:" Margin="0,0,0,6"/>
                <TextBox x:Name="SshUserBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="SSH Password:" Margin="0,0,0,6"/>
                <PasswordBox x:Name="SshPasswordBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Private Key File:" Margin="0,0,0,6"/>
                <TextBox x:Name="SshKeyPathBox" Grid.Row="4" Grid.Column="1" Margin="0,0,6,6" IsReadOnly="True"/>
                <Button Grid.Row="4" Grid.Column="2" Content="Browse…" Width="70" Margin="0,0,0,6" Click="BrowseKey_Click"/>

                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Remote MySQL:"/>
                <Grid Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SshRemoteHostBox" Grid.Column="0" Margin="0,0,6,0"/>
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Port:" Margin="0,0,6,0"/>
                    <TextBox x:Name="SshRemotePortBox" Grid.Column="2"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Status -->
        <StackPanel Margin="0,10,0,0">
            <TextBlock Text="Status:" FontWeight="Bold"/>
            <TextBox x:Name="StatusBox" Height="120" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
            <TextBlock x:Name="ConfigPathText" Margin="0,6,0,0" FontStyle="Italic" Foreground="Gray"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Test" Width="90" Margin="0,0,10,0" Click="Test_Click"/>
            <Button Content="Migrate" Width="90" Margin="0,0,10,0" Click="Migrate_Click"/>
            <Button Content="Save" Width="90" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Close" Width="90" Click="Close_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
