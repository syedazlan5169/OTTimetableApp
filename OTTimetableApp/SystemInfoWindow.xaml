<Window x:Class="OTTimetableApp.SystemInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Info" Height="390" Width="420" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Application -->
        <TextBlock Text="Application" FontWeight="Bold" FontSize="13"/>
        <Grid Grid.Row="1" Margin="0,6,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Version:" Foreground="Gray"/>
            <TextBlock x:Name="VersionText" Grid.Column="1" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1" Text=".NET Runtime:" Foreground="Gray"/>
            <TextBlock x:Name="RuntimeText" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold"/>
        </Grid>

        <!-- Database -->
        <TextBlock Grid.Row="2" Text="Database" FontWeight="Bold" FontSize="13"/>
        <Grid Grid.Row="3" Margin="0,6,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Host:" Foreground="Gray"/>
            <TextBlock x:Name="HostText" Grid.Column="1" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1" Text="Database:" Foreground="Gray"/>
            <TextBlock x:Name="DbNameText" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="2" Text="Last Migration:" Foreground="Gray"/>
            <TextBlock x:Name="MigrationText" Grid.Row="2" Grid.Column="1" FontWeight="SemiBold" TextWrapping="Wrap"/>
        </Grid>

        <!-- Data Summary -->
        <TextBlock Grid.Row="4" Text="Data Summary" FontWeight="Bold" FontSize="13" VerticalAlignment="Top"/>
        <Grid Grid.Row="4" Margin="0,24,0,0" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Employees (active):" Foreground="Gray"/>
            <TextBlock x:Name="EmployeeText" Grid.Column="1" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1" Text="Groups:" Foreground="Gray"/>
            <TextBlock x:Name="GroupText" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="2" Text="Calendars:" Foreground="Gray"/>
            <TextBlock x:Name="CalendarText" Grid.Row="2" Grid.Column="1" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="3" Text="Audit Log Entries:" Foreground="Gray"/>
            <TextBlock x:Name="AuditLogText" Grid.Row="3" Grid.Column="1" FontWeight="SemiBold"/>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Refresh" Width="80" Margin="0,0,10,0" Click="Refresh_Click"/>
            <Button Content="Close" Width="80" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
