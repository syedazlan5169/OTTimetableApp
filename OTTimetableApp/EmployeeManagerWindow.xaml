<Window x:Class="OTTimetableApp.EmployeeManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Manager" Height="650" Width="1100"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: list -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search -->
            <TextBox Grid.Row="0"
             Height="28"
             Margin="0,0,0,8"
             Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
             ToolTip="Search by short name / full name / IC"/>

            <!-- List -->
            <DataGrid Grid.Row="1"
              ItemsSource="{Binding Employees}"
              SelectedItem="{Binding SelectedEmployee}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Short" Binding="{Binding Name}" Width="80"/>
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="New" Width="90" Margin="0,0,8,0" Click="New_Click"/>
                <Button Content="Delete" Width="90" Click="Delete_Click"/>
            </StackPanel>
        </Grid>

        <!-- RIGHT: editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Employee Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Short Name:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Height="26" Text="{Binding Edit.Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Full Name:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Height="26" Text="{Binding Edit.FullName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="No. KP:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Height="26" Text="{Binding Edit.IcNo, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="No. PiK:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Height="26" Text="{Binding Edit.PikNo, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Cawangan:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Height="26" Text="{Binding Edit.Branch, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="No. Telefon:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Height="26" Text="{Binding Edit.PhoneNo, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Gaji (RM):" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Height="26" Text="{Binding Edit.Salary, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="No. Gaji:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Height="26" Text="{Binding Edit.SalaryNo, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Nama Bank:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Height="26" Text="{Binding Edit.BankName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Akaun Bank:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="9" Grid.Column="1" Height="26" Text="{Binding Edit.BankAccountNo, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Base Group:" VerticalAlignment="Center"/>
                    <DockPanel Grid.Row="10" Grid.Column="1">
                        <ComboBox Width="220"
                                  ItemsSource="{Binding Groups}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding Edit.BaseGroupId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    <Setter Property="IsEditable" Value="False"/>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>

                        <TextBlock Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="DimGray"
                                   Text="{Binding Edit.BaseGroupId, StringFormat=BaseGroupId: {0}}"/>
                    </DockPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <Button Content="Save" Width="120" Click="Save_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>